# Backend Production Environment Variables Example
# Duplicate this file as .env in the backend folder and customize values.

# API Prefix
API_V1_STR=/api/v1
PROJECT_NAME="Football Analytics & Prediction Platform"

# Allowed CORS Origins (comma-separated list)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-frontend.vercel.app

# Database Connection (e.g., PostgreSQL URL provided by Railway)
DATABASE_URL=postgresql://user:password@host:port/dbname

# Workspace path (optional, defaults to relative lookup)
FIFA_PROJECT_ROOT=/app
